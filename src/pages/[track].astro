---
import Layout from '@layouts/Layout.astro'
import AlgoViz from '@components/AlgoViz'
import { tracks } from '@lib/tests'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = () => {
  return tracks.map((t) => ({
    params: { track: t.id },
  }))
}

const { track } = Astro.params as { track: string }
const trackObj = tracks.find((t) => t.id === track)!

const title = trackObj.name
const description = `Candidate Evaluation Track: ${trackObj.name}`
---

<Layout locale="en" title={title} description={description}>
  <AlgoViz locale="en" initialTrackId={track} client:load />
</Layout>
